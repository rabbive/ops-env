# Copy to .env and fill in (never commit secrets). For Hugging Face Spaces, set the same
# names under Settings → Secrets and variables.

# Required for LLM inference (OpenAI-compatible API)
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=
HF_TOKEN=

# Optional: use a deployed Space as the environment (HTTPS URL). If unset, inference uses
# local Docker (ENV_IMAGE_NAME).
# ENV_BASE_URL=https://your-org-your-space.hf.space

# Optional overrides
# ENV_IMAGE_NAME=supportdesk-env:latest
# MAX_STEPS=20
# INFERENCE_VERBOSE=1
